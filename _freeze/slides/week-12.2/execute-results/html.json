yle>\n    <div class=\"container\">\n      <table class=\"tinytable\" id=\"tinytable_qlp5itbwhgrkfpo3wea5\" style=\"width: auto; margin-left: auto; margin-right: auto;\" data-quarto-disable-processing='true'>\n        <caption>Table 1: Predictors of Conflict Onset</caption>\n        <thead>\n              <tr>\n                <th scope=\"col\" data-row=\"0\" data-col=\"1\"> </th>\n                <th scope=\"col\" data-row=\"0\" data-col=\"2\">Ethnicity</th>\n                <th scope=\"col\" data-row=\"0\" data-col=\"3\">Democracy</th>\n                <th scope=\"col\" data-row=\"0\" data-col=\"4\">Terrain</th>\n                <th scope=\"col\" data-row=\"0\" data-col=\"5\">Full Model</th>\n              </tr>\n        </thead>\n        <tfoot><tr><td colspan='5'>+ p < 0.1, * p < 0.05, ** p < 0.01, *** p < 0.001</td></tr>\n<tr><td colspan='5'>See appendix for data sources.</td></tr></tfoot>\n        <tbody>\n                <tr>\n                  <td data-row=\"1\" data-col=\"1\">Ethnic Frac</td>\n                  <td data-row=\"1\" data-col=\"2\">0.733*</td>\n                  <td data-row=\"1\" data-col=\"3\"></td>\n                  <td data-row=\"1\" data-col=\"4\"></td>\n                  <td data-row=\"1\" data-col=\"5\">0.709+</td>\n                </tr>\n                <tr>\n                  <td data-row=\"2\" data-col=\"1\"></td>\n                  <td data-row=\"2\" data-col=\"2\">(0.365)</td>\n                  <td data-row=\"2\" data-col=\"3\"></td>\n                  <td data-row=\"2\" data-col=\"4\"></td>\n                  <td data-row=\"2\" data-col=\"5\">(0.372)</td>\n                </tr>\n                <tr>\n                  <td data-row=\"3\" data-col=\"1\">Religions Frac</td>\n                  <td data-row=\"3\" data-col=\"2\">-0.429</td>\n                  <td data-row=\"3\" data-col=\"3\"></td>\n                  <td data-row=\"3\" data-col=\"4\"></td>\n                  <td data-row=\"3\" data-col=\"5\">-0.288</td>\n              