"3\">-0.275***</td>\n                  <td data-row=\"9\" data-col=\"4\">-0.553***</td>\n                  <td data-row=\"9\" data-col=\"5\">-0.392**</td>\n                </tr>\n                <tr>\n                  <td data-row=\"10\" data-col=\"1\"></td>\n                  <td data-row=\"10\" data-col=\"2\">(0.104)</td>\n                  <td data-row=\"10\" data-col=\"3\">(0.059)</td>\n                  <td data-row=\"10\" data-col=\"4\">(0.092)</td>\n                  <td data-row=\"10\" data-col=\"5\">(0.120)</td>\n                </tr>\n                <tr>\n                  <td data-row=\"11\" data-col=\"1\">Population</td>\n                  <td data-row=\"11\" data-col=\"2\">0.278***</td>\n                  <td data-row=\"11\" data-col=\"3\">0.300***</td>\n                  <td data-row=\"11\" data-col=\"4\">0.296***</td>\n                  <td data-row=\"11\" data-col=\"5\">0.285***</td>\n                </tr>\n                <tr>\n                  <td data-row=\"12\" data-col=\"1\"></td>\n                  <td data-row=\"12\" data-col=\"2\">(0.067)</td>\n                  <td data-row=\"12\" data-col=\"3\">(0.051)</td>\n                  <td data-row=\"12\" data-col=\"4\">(0.050)</td>\n                  <td data-row=\"12\" data-col=\"5\">(0.068)</td>\n                </tr>\n                <tr>\n                  <td data-row=\"13\" data-col=\"1\">Intercept</td>\n                  <td data-row=\"13\" data-col=\"2\">-4.571***</td>\n                  <td data-row=\"13\" data-col=\"3\">-6.184***</td>\n                  <td data-row=\"13\" data-col=\"4\">-4.166***</td>\n                  <td data-row=\"13\" data-col=\"5\">-5.376***</td>\n                </tr>\n                <tr>\n                  <td data-row=\"14\" data-col=\"1\"></td>\n                  <td data-row=\"14\" data-col=\"2\">(1.323)</td>\n                  <td data-row=\"14\" data-col=\"3\">(0.967)</td>\n                  <td data-row=\"14\" data-col=\"4\">(1.140)</td>\n               